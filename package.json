{
  "name": "mutualzz",
  "private": true,
  "description": "Social media app for everyone, especially alternative people",
  "version": "6.0.0",
  "author": "Mutualzz",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "typecheck": "turbo run typecheck",
    "prestart": "pnpm install && pnpm build:packages && pnpm build:server",
    "gen-changelog": "node scripts/generateChangelog.mjs",
    "build:server": "turbo run build --filter=\"./apps/server\"",
    "build:packages": "turbo run build --filter=\"./packages/types\" --filter=\"./packages/logger\" --filter=\"./packages/ui-core\" --filter=\"./packages/ui-web\" --filter=\"./packages/ui-native\" --filter=\"./packages/validators\" --filter=\"./packages/bitfield\" --filter=\"./packages/color-picker\" --filter=\"./packages/contexify\" --filter=\"./packages/i18n\"",
    "build:ui": "turbo run build --filter=\"./packages/ui-web\" --filter=\"./packages/ui-native\"",
    "build:voice": "turbo run build --filter=\"./apps/voice\"",
    "prepare": "husky",
    "dev:frontend": "turbo run dev --filter=\"./apps/app\" --filter=\"./packages/ui\"",
    "release": "git checkout release && git merge master && git push origin release && git checkout master",
    "init-submodules": "git submodule update --init --recursive && git submodule foreach git checkout master",
    "pull": "git pull origin master && git submodule foreach git pull origin master",
    "delete-all-node-modules": "rm -rfv node_modules && git submodule foreach rm -rfv node_modules",
    "demo:seed": "pnpm --filter @mutualzz/server demo:seed",
    "demo:clean": "pnpm --filter @mutualzz/server demo:clean",
    "i18n": "pnpm --filter @mutualzz/i18n refresh"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "prettier": "^3.8.3",
    "prettier-plugin-organize-imports": "^4.3.0",
    "turbo": "^2.9.16",
    "typescript": "~6.0.3",
    "node-addon-api": "^8.8.0",
    "node-gyp": "^12.3.0"
  },
  "engines": {
    "node": ">=22"
  },
  "workspaces": [
    "apps/*",
    "packages/*",
    "tooling/*"
  ],
  "packageManager": "pnpm@11.5.2"
}
